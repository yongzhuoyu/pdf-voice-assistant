# Copy this file to `.env` and fill in real keys. `.env` is gitignored — never commit keys.

# Required for Day 1 (contextualizer + answer generation).
# Get one at https://console.anthropic.com/ → API Keys. Needs billing/credits enabled.
ANTHROPIC_API_KEY=sk-ant-...

# Required for Day 2 voice features (Deepgram ASR + Aura TTS).
# Get one at https://console.deepgram.com/ ($200 free credit). One key for both.
DEEPGRAM_API_KEY=...
